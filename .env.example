# Resend — used by the /api/contact route to deliver form submissions.
# Server-only; never imported into client bundles.
RESEND_API_KEY=

# Where contact-form messages should be delivered.
CONTACT_TO_EMAIL=

# Verified sender on Resend.  Until a custom domain is added,
# Resend's onboarding sender works out of the box.
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# Cloudflare Turnstile — bot protection on the contact form.
# Site key is exposed to the browser (NEXT_PUBLIC_); secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Site URL ────────────────────────────────────────────────────────────
# Canonical origin for this deployment. Used to build magic-link redirect
# URLs and OG/canonical metadata. In production set to https://saranzafar.com.
# In local dev leave unset (the auth flow falls back to the request origin
# when the host is localhost) OR set to http://localhost:3000 to be explicit.
NEXT_PUBLIC_SITE_URL=

# ─── Supabase (admin backend) ────────────────────────────────────────────
# Get these from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by route handlers that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin allow-list ────────────────────────────────────────────────────
# Comma-separated list of email addresses that can sign in to /admin.
# Anyone else gets blocked at both the middleware and the Supabase RLS layer.
ADMIN_EMAILS=saran.development@gmail.com

# ─── Hero music dock ─────────────────────────────────────────────────────
# Public SoundCloud URL the hidden Widget iframe streams from. Can be a
# set (playlist), a single track, or a user URL. No API key required.
NEXT_PUBLIC_MUSIC_PLAYLIST_URL=https://soundcloud.com/chillhopdotcom/sets/chillhop-essentials-fall-2023
